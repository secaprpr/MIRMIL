+        if self.split_csv is not None:
+            split = pd.read_csv(self.split_csv)
+            path_column = f"{data_set}_slide_path"
+            label_column = f"{data_set}_label"
+            paths = split[path_column].dropna().tolist()
+            labels = split[label_column].dropna().astype(int).tolist()
+            if len(paths) != len(labels):
+                raise ValueError(f"mismatched paths and labels for {data_set}")
+            max_len = 0
+            for full_path, label in zip(paths, labels):
+                slide_id = os.path.splitext(os.path.basename(full_path))[0]
+                features = self.get_data(full_path)
+                if isinstance(features, dict):
+                    features = features.get('features', features.get('feats'))
+                if features.ndim == 3:
+                    features = features.squeeze(0)
+                if self.max_instances and features.shape[0] > self.max_instances:
+                    indices = torch.linspace(
+                        0, features.shape[0] - 1, self.max_instances
+                    ).long()
+                    features = features[indices]
+                wsis[slide_id] = int(label)
+                data[slide_id] = features
+                max_len = max(max_len, int(features.shape[0]))
+            self.max_len = max_len
+            print('Max len: ', self.max_len)
+            print('Number of slides in {} set: {}'.format(data_set, len(wsis)))
+            return wsis, data
